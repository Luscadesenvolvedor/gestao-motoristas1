// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Papel {
  admin
  guiche
  acertador
  dgp
  financeiro
  levantamentos
}

enum Frota {
  buzin
  meli
  lbm
  meli_buzin
  meli_lbm
}

enum StatusMotorista {
  ativo
  desligado
}

enum CategoriaMotorista {
  frota
  dedicado_usiminas
  dedicado_arcelormittal
  patio
  tirador_ferias
}

enum StatusSolicitacao {
  pendente
  pago
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  papel     Papel
  ativo     Boolean  @default(true)
  setor     String   @default("acerto")
  permissoes Json?
  criadoEm  DateTime @default(now())
  perfilAgendamento Int?
  perfilFinanceiro  Int?

  solicitacoes      Solicitacao[]
  exclusoes         ExclusaoVale[]
  auditoriasFeitas  Auditoria[]
  financeiros       ControleFinanceiro[] @relation("FinanceiroUsuario")
  valesFixos         ValeFixo[]
  levantamentos      Levantamento[]
  notasAbastecimento NotaAbastecimento[]
  faturasAbastecimento FaturaAbastecimento[] @relation("FaturasAbastecimento")

  @@map("usuarios")
}

model Motorista {
  id           String             @id @default(uuid())
  nome         String
  cpf          String             @unique
  contato      String
  banco        String?
  agencia      String?
  conta        String?
  pix          String?
  destinatario String?
  frota        Frota
  status       StatusMotorista    @default(ativo)
  categoria    CategoriaMotorista
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt
  excluido          Boolean            @default(false)
  dataDesligamento   DateTime?
  descricao          String?

  solicitacoes       Solicitacao[]
  exclusoes          ExclusaoVale[]
  folgas             Folga[]
  ferias             Ferias[]
  agendamentos       Agendamento[]
  controleFinanceiro ControleFinanceiro[]
  auditorias         Auditoria[]
  afastamentos       Afastamento[]
  abandonos          Abandono[]
  valesFixos         ValeFixo[]

  @@map("motoristas")
}

model TipoSolicitacao {
  id           String        @id @default(uuid())
  nome         String        @unique
  ativo        Boolean       @default(true)
  solicitacoes Solicitacao[]

  @@map("tipos_solicitacao")
}

model TipoVale {
  id           String        @id @default(uuid())
  nome         String        @unique
  ativo        Boolean       @default(true)
  solicitacoes Solicitacao[]

  @@map("tipos_vale")
}

model TipoRef {
  id           String        @id @default(uuid())
  nome         String        @unique
  ativo        Boolean       @default(true)
  solicitacoes Solicitacao[]

  @@map("tipos_ref")
}

model Solicitacao {
  id            String            @id @default(uuid())
  solicitante   Usuario           @relation(fields: [solicitanteId], references: [id])
  solicitanteId String
  data          DateTime
  tipo          TipoSolicitacao   @relation(fields: [tipoId], references: [id])
  tipoId        String
  tipoVale      TipoVale?         @relation(fields: [tipoValeId], references: [id])
  tipoValeId    String?
  tipoRef       TipoRef?          @relation(fields: [tipoRefId], references: [id])
  tipoRefId     String?
  motorista     Motorista         @relation(fields: [motoristaId], references: [id])
  motoristaId   String
  placa         String?
  valor         Decimal           @db.Decimal(10, 2)
  liberado           Decimal?          @db.Decimal(10, 2)
  liberadoExportado  Decimal           @default(0) @db.Decimal(10, 2)
  status             StatusSolicitacao @default(pendente)
  dataPagamento DateTime?
  realizadoPor  String?
  prioridade    Boolean   @default(false)
  observacao    String?
  criadoEm     DateTime          @default(now())
  atualizadoEm  DateTime          @updatedAt

  auditorias Auditoria[]	

  @@map("solicitacoes")
}

model ExclusaoVale {
  id            String    @id @default(uuid())
  solicitante   Usuario   @relation(fields: [solicitanteId], references: [id])
  solicitanteId String
  numeroVale    String
  dataVale      DateTime
  motorista     Motorista @relation(fields: [motoristaId], references: [id])
  motoristaId   String
  motivo        String
  feito         Boolean   @default(false)
  criadoEm     DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  observacao   String?

  auditorias Auditoria[]

  @@map("exclusoes_vale")
}

model Folga {
  id             String    @id @default(uuid())
  motorista      Motorista @relation(fields: [motoristaId], references: [id])
  motoristaId    String
  periodo        String
  quantidadeDias Int
  valorTotal     Decimal   @db.Decimal(10, 2)
  enviado        Boolean   @default(false)
  criadoEm      DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  auditorias Auditoria[]

  @@map("folgas")
}

model Ferias {
  id             String    @id @default(uuid())
  motorista      Motorista @relation(fields: [motoristaId], references: [id])
  motoristaId    String
  tipo           String    @default("ferias")
  inicio         DateTime
  fim            DateTime?
  quantidadeDias Int?
  observacao     String?
  criadoEm      DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  auditorias Auditoria[] @relation("FeriasAuditoria")

  @@map("ferias")
}

model Afastamento {
  id            String    @id @default(uuid())
  motorista     Motorista @relation(fields: [motoristaId], references: [id])
  motoristaId   String
  dataInicio    DateTime
  dataRetorno   DateTime?
  indeterminado Boolean   @default(false)
  retornou      Boolean   @default(false)
  observacao    String?
  criadoEm     DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@map("afastamentos")
}

model Abandono {
  id          String    @id @default(uuid())
  motorista   Motorista @relation(fields: [motoristaId], references: [id])
  motoristaId String
  data        DateTime
  observacao  String?
  criadoEm   DateTime  @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("abandonos")
}

model Agendamento {
  id                String    @id @default(uuid())
  perfil            Int
  motorista         Motorista @relation(fields: [motoristaId], references: [id])
  motoristaId       String
  mesesAcerto       Int
  mesesSelecionados String[]  @default([])
  dataHora          DateTime
  criadoEm         DateTime  @default(now())
  atualizadoEm     DateTime  @updatedAt

  auditorias Auditoria[]

  @@map("agendamentos")
}

model TipoDesconto {
  id                 String               @id @default(uuid())
  nome               String               @unique
  ativo              Boolean              @default(true)
  controleFinanceiro ControleFinanceiro[]

  @@map("tipos_desconto")
}

model ControleFinanceiro {
  id              String       @id @default(uuid())
  motorista       Motorista    @relation(fields: [motoristaId], references: [id])
  motoristaId     String
  tipoDesconto    TipoDesconto @relation(fields: [tipoDescontoId], references: [id])
  tipoDescontoId  String
  valor           Decimal      @db.Decimal(10, 2)
  valorDescontado Decimal      @db.Decimal(10, 2)
  numeroAcerto    String
  numeroVale      String?
  mesDesconto     String?
  observacao      String?
  abonado         Boolean      @default(false)
  abonadoPor      String?
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt
  usuarioId       String?

  auditorias        Auditoria[]
  usuario           Usuario? @relation("FinanceiroUsuario", fields: [usuarioId], references: [id])
  parcelasDesconto  ParcelaDesconto[]

  @@map("controle_financeiro")
}

model ParcelaDesconto {
  id                   String             @id @default(uuid())
  controleFinanceiro   ControleFinanceiro @relation(fields: [controleFinanceiroId], references: [id], onDelete: Cascade)
  controleFinanceiroId String
  mes                  String
  valor                Decimal            @db.Decimal(10, 2)
  criadoEm             DateTime           @default(now())

  @@map("parcelas_desconto")
}

model Auditoria {
  id         String   @id @default(uuid())
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId  String
  acao       String
  tabela     String
  registroId String

  motorista     Motorista?          @relation(fields: [motoristaId], references: [id])
  motoristaId   String?
  solicitacao   Solicitacao?        @relation(fields: [solicitacaoId], references: [id])
  solicitacaoId String?
  exclusao      ExclusaoVale?       @relation(fields: [exclusaoId], references: [id])
  exclusaoId    String?
  folga         Folga?              @relation(fields: [folgaId], references: [id])
  folgaId       String?
  ferias        Ferias?             @relation("FeriasAuditoria", fields: [feriasId], references: [id])
  feriasId      String?
  agendamento   Agendamento?        @relation(fields: [agendamentoId], references: [id])
  agendamentoId String?
  controle      ControleFinanceiro? @relation(fields: [controleId], references: [id])
  controleId    String?

  dadosAntigos Json?
  dadosNovos   Json?
  criadoEm    DateTime @default(now())

  @@map("auditorias")
}

model ValeFixo {
  id            String    @id @default(uuid())
  motorista     Motorista @relation(fields: [motoristaId], references: [id])
  motoristaId   String
  dataPagamento DateTime
  valor         Decimal   @db.Decimal(10, 2)
  exportado     Boolean   @default(false)
  usuarioId     String
  usuario       Usuario   @relation(fields: [usuarioId], references: [id])
  criadoEm     DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@map("vales_fixos")
}

model Levantamento {
  id                 String   @id @default(uuid())
  mes                String
  tipo               String   @default("FROTA")
  motoristasFechados Int      @default(0)
  previa             Decimal  @default(0) @db.Decimal(10, 2)
  saldo              Decimal  @default(0) @db.Decimal(10, 2)
  custoFolha         Decimal  @default(0) @db.Decimal(10, 2)
  observacao         String?
  usuarioId          String?
  usuario            Usuario? @relation(fields: [usuarioId], references: [id])
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  @@unique([mes, tipo])
  @@map("levantamentos")
}

model FornecedorAbastecimento {
  id          String   @id @default(uuid())
  razaoSocial String
  cnpj        String
  responsavel String?
  contato     String?
  tipoServico    String   // 'lavagem' | 'estacionamento'
  frota          String   @default("buzin") // 'buzin' | 'lbm'
  formaPagamento String   @default("pix") // 'pix' | 'boleto'
  chavePix       String?
  numeroOC       String?
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  faturas FaturaAbastecimento[]

  @@map("fornecedores_abastecimento")
}

model FaturaAbastecimento {
  id             String                  @id @default(uuid())
  fornecedor     FornecedorAbastecimento @relation(fields: [fornecedorId], references: [id])
  fornecedorId   String
  numero         String
  valor          Decimal                 @db.Decimal(10, 2)
  dataVencimento DateTime                @db.Date
  dataPagamento  DateTime?               @db.Date
  status         String                  @default("pendente")
  arquivoNome    String?
  arquivoBase64  String?
  arquivoTipo    String?
  observacao     String?
  usuarioId      String
  usuario        Usuario                 @relation("FaturasAbastecimento", fields: [usuarioId], references: [id])
  criadoEm      DateTime                @default(now())
  atualizadoEm  DateTime                @updatedAt

  notasFiscais NotaFiscalAbastecimento[]

  @@map("faturas_abastecimento")
}

model NotaFiscalAbastecimento {
  id            String              @id @default(uuid())
  fatura        FaturaAbastecimento @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  faturaId      String
  numero        String
  valor         Decimal             @db.Decimal(10, 2)
  arquivoNome   String?
  arquivoBase64 String?
  arquivoTipo   String?
  criadoEm     DateTime            @default(now())

  @@map("notas_fiscais_abastecimento")
}

model NotaAbastecimento {
  id             String   @id @default(uuid())
  tipo           String   // 'nota' | 'remessa'
  numero         String
  fornecedor     String
  descricao      String?
  valor          Decimal  @db.Decimal(10, 2)
  dataEmissao    DateTime @db.Date
  dataVencimento DateTime @db.Date
  dataPagamento  DateTime? @db.Date
  status         String   @default("pendente") // 'pendente' | 'pago' | 'vencido'
  observacao     String?
  usuarioId      String
  usuario        Usuario  @relation(fields: [usuarioId], references: [id])
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@map("notas_abastecimento")
}

model Notificacao {
  id        String   @id @default(uuid())
  titulo    String
  mensagem  String
  tipo      String
  lida      Boolean  @default(false)
  usuarioId String?
  criadoEm DateTime @default(now())

  @@map("notificacoes")
}